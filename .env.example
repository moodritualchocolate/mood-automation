# ─────────────────────────────────────────────────────────────
# MOOD Procurement Hub — environment configuration
#
# The app runs out-of-the-box in LOCAL mode (no backend required):
# data is stored in the browser and synced live across tabs/devices
# on the same machine. To enable the multi-device cloud backend,
# create a Supabase project and fill in the values below.
# ─────────────────────────────────────────────────────────────

# Supabase — https://app.supabase.com  → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: AI Assistant ("נתח ספק"). When set, supplier analysis
# uses the Claude API; otherwise a built-in heuristic analysis is used.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
