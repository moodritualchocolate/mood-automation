# MOOD CREATIVE OS — environment
# All keys are OPTIONAL. With keys, engines run on real providers.
# Without keys, engines fall back to deterministic curated banks
# so the system stays runnable end-to-end during development.

# Anthropic (used by: Human Truth, Creative Director, Critic)
ANTHROPIC_API_KEY=

# OpenAI (used by: Image Generation Engine — gpt-image-1)
OPENAI_API_KEY=

# Memory store directory (default ./data/memory)
MOOD_MEMORY_DIR=

# Set to "1" to force stub providers even when keys are present
MOOD_FORCE_STUBS=
