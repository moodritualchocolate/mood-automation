# MOOD — Social Video Review configuration (copy to .env or export in shell).
# NOTE: v1 NEVER publishes. These credentials are only used to check whether a
# connection *could* work. Publishing stays disabled regardless.

# --- Server ---
PORT=4310
# Absolute path to the folder to watch. In production point this at your real
# "/content/social-videos-to-review/" directory.
# WATCH_DIR=/content/social-videos-to-review
SCAN_INTERVAL_MS=5000

# --- Brand defaults (used by the recommendation engine) ---
BRAND_NAME=MOOD
BRAND_HANDLE=@moodritualchocolate
# BRAND_CTA=הזמינו עכשיו דרך הקישור בביו 🍫
# BRAND_DESCRIPTION fed to Claude so recommendations stay on-brand.
# BRAND_DESCRIPTION=MOOD Ritual Chocolate — שוקולד וקקאו טקסי, נקי ואמיתי...

# --- Claude API (content-based recommendations) ---
# When ANTHROPIC_API_KEY is set, new videos are analyzed by extracting key
# frames (requires ffmpeg on PATH) and sending them to Claude, which returns
# Hebrew recommendations in 4 styles. Without a key, an offline heuristic is
# used instead. This never publishes anything.
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-opus-4-8
# CLAUDE_FRAME_COUNT=6
# CLAUDE_MAX_TOKENS=16000

# --- Audio transcription (optional, pluggable) ---
# Anthropic has no speech-to-text, so transcription uses an external engine.
# Audio is extracted with ffmpeg, then transcribed via EITHER a Whisper-compatible
# HTTP endpoint (preferred) OR a local `whisper` CLI. If neither is available, or
# the video has no audio, the system simply continues without a transcript.
# TRANSCRIBE_ENABLED=true
# Whisper-compatible HTTP endpoint (e.g. self-hosted Whisper, Groq, etc.):
# TRANSCRIBE_API_URL=https://your-whisper-endpoint/v1/audio/transcriptions
# TRANSCRIBE_API_KEY=
# TRANSCRIBE_MODEL=whisper-1
# Force a language, or leave blank to auto-detect Hebrew/English:
# TRANSCRIBE_LANGUAGE=
# Local OpenAI-Whisper CLI fallback (used only if no HTTP endpoint set):
# WHISPER_BIN=whisper
# WHISPER_MODEL=base

# === Publishing — Phase 1: YouTube Shorts ONLY ===============================
# YouTube is the only platform that can publish. Create an OAuth 2.0 "Web
# application" client in Google Cloud (YouTube Data API v3 enabled), add the
# redirect URI below to its Authorized redirect URIs, then click "Connect
# YouTube" on the Platform Connections page.
# YT_CLIENT_ID=
# YT_CLIENT_SECRET=
# Must exactly match an Authorized redirect URI on the OAuth client:
# YT_REDIRECT_URI=http://localhost:4310/api/youtube/oauth/callback
# Privacy of published Shorts: public | unlisted | private.
# Default is 'public'. Use 'unlisted' or 'private' for safe end-to-end testing.
# YT_PRIVACY_STATUS=public
# YT_CATEGORY_ID=22

# --- Connection-check stubs (NOT built for publishing yet) -------------------
# Instagram / Facebook / TikTok are connection-check stubs only in this phase —
# they cannot publish. Presence of these vars just flips the card to "connected".
# IG_ACCESS_TOKEN=
# IG_BUSINESS_ID=
# IG_ACCOUNT_NAME=
# FB_PAGE_ACCESS_TOKEN=
# FB_PAGE_ID=
# FB_ACCOUNT_NAME=
# TIKTOK_ACCESS_TOKEN=
# TIKTOK_OPEN_ID=
# TIKTOK_ACCOUNT_NAME=
